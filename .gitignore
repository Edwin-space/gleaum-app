# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Capacitor / Native App ────────────────────────────────────────────────────
# iOS — CocoaPods 캐시 (npx cap sync 시 자동 복원)
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/.xcode.env.local

# Android — Gradle 빌드 캐시
android/.gradle/
android/app/build/
android/build/
android/local.properties

# 네이티브 빌드 출력 (정적 export — 현재 미사용)
/out/

# Android 키스토어 (절대 커밋 금지)
*.keystore
*.jks
