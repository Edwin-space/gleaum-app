<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- 상단 브랜딩 (60%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/login_gradient_bg"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher_foreground"
            android:contentDescription="글리움 로고" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="gleaum"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="나, 그리고 연인/가족의\n일상 네트워크"
            android:textColor="#8E8E93"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="40dp">

        <!-- Google 로그인 버튼 -->
        <RelativeLayout
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/btn_google_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/googleIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="20dp"
                android:src="@drawable/ic_google"
                android:contentDescription="Google" />

            <TextView
                android:id="@+id/btnGoogleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Google로 계속하기"
                android:textColor="#1A1B2E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/googleLoading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerInParent="true"
                android:visibility="gone"
                android:indeterminateTint="#1A1B2E" />

        </RelativeLayout>

        <!-- 이메일 링크 -->
        <TextView
            android:id="@+id/btnEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="이메일 주소로 사용하기"
            android:textColor="#8E8E93"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <!-- 약관 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="로그인 시 이용약관 및 개인정보처리방침에\n동의하는 것으로 간주됩니다."
            android:textColor="#48484A"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

</LinearLayout>
