<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/loginRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="640dp"
        android:orientation="vertical"
        android:background="#000000">

        <!-- 상단 브랜딩 -->
        <LinearLayout
            android:id="@+id/brandPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/login_gradient_bg"
            android:padding="32dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher_foreground"
                android:contentDescription="글리움 로고" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="gleaum"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="나, 그리고 연인/가족의\n일상 네트워크"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- 로그인 컨트롤 -->
        <LinearLayout
            android:id="@+id/controlPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:id="@+id/socialPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Google 로그인 버튼 -->
                <RelativeLayout
                    android:id="@+id/btnGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/btn_google_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/googleIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_google"
                        android:contentDescription="Google" />

                    <TextView
                        android:id="@+id/btnGoogleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="Google로 계속하기"
                        android:textColor="#1A1B2E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/googleLoading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerInParent="true"
                        android:visibility="gone"
                        android:indeterminateTint="#1A1B2E" />

                </RelativeLayout>

                <TextView
                    android:id="@+id/btnEmail"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_email_bg"
                    android:gravity="center"
                    android:text="이메일로 계속하기"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emailPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btnEmailBack"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="← 다른 방법으로 계속하기"
                    android:textColor="#8E8E93"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/emailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="이메일로 로그인"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/emailSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="글리움 계정 이메일과 비밀번호를 입력해 주세요."
                    android:textColor="#8E8E93"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/inputName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/input_bg"
                    android:hint="이름 또는 닉네임"
                    android:inputType="textPersonName"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6E6E73"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/inputEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_bg"
                    android:hint="이메일"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6E6E73"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_bg"
                    android:hint="비밀번호"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6E6E73"
                    android:textSize="15sp" />

                <LinearLayout
                    android:id="@+id/consentPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <CheckBox
                        android:id="@+id/checkAllConsents"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:buttonTint="#0CC9B5"
                        android:text="[필수] 전체 동의"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <CheckBox
                        android:id="@+id/checkAge"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:buttonTint="#0CC9B5"
                        android:text="[필수] 만 14세 이상입니다."
                        android:textColor="#D1D5DB"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/checkTerms"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:buttonTint="#0CC9B5"
                            android:text="[필수] 이용약관에 동의합니다."
                            android:textColor="#D1D5DB"
                            android:textSize="13sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/linkTerms"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="4dp"
                            android:text="보기"
                            android:textColor="#0CC9B5"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/checkPrivacy"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:buttonTint="#0CC9B5"
                            android:text="[필수] 개인정보 수집·이용에 동의합니다."
                            android:textColor="#D1D5DB"
                            android:textSize="13sp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/linkPrivacy"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="4dp"
                            android:text="보기"
                            android:textColor="#0CC9B5"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/emailError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#F87171"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/btnEmailSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/btn_primary_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/btnEmailSubmitText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="로그인"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/emailLoading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#FFFFFF" />
                </FrameLayout>

                <TextView
                    android:id="@+id/btnToggleEmailMode"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="계정이 없으신가요? 회원가입"
                    android:textColor="#0CC9B5"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/legalNotice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:text="로그인 시 이용약관 및 개인정보처리방침에\n동의하는 것으로 간주됩니다."
                android:textColor="#48484A"
                android:textSize="11sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
