<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <!-- 뒤로가기 -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="← 뒤로"
        android:textColor="#8E8E93"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true" />

    <!-- 콘텐츠 가운데 정렬 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- 이메일 입력 단계 -->
        <LinearLayout
            android:id="@+id/emailStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이메일로 로그인"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="이전에 Google로 가입한 이메일 주소를 입력하세요.\n6자리 인증 코드를 보내드립니다."
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />

            <EditText
                android:id="@+id/inputEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:hint="이메일 주소"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#8E8E93"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/input_bg" />

            <Button
                android:id="@+id/btnSendOtp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="인증 코드 발송"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary_bg"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- OTP 입력 단계 -->
        <LinearLayout
            android:id="@+id/otpStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="인증 코드 입력"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/otpDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="6자리 코드를 보냈습니다."
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />

            <EditText
                android:id="@+id/inputOtp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:hint="6자리 코드"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:textColor="#FFFFFF"
                android:textColorHint="#8E8E93"
                android:textSize="18sp"
                android:gravity="center"
                android:letterSpacing="0.3"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/input_bg" />

            <Button
                android:id="@+id/btnVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="확인"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary_bg"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/btnResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="코드 재발송"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
