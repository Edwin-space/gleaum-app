<?xml version="1.0" encoding="utf-8"?>
<!--
  글리움 스플래시 화면 레이아웃
  배경: #0A0B10 (다크 블랙)
  구성: 상단 텍스트 + 우측 로고 + 하단 브랜드
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B10">

    <!-- ── 로고 아이콘: 중앙 우측 배치, 약간 하단 오프셋 ── -->
    <ImageView
        android:id="@+id/splashLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginTop="110dp"
        android:layout_marginEnd="-18dp"
        android:src="@drawable/splash_icon"
        android:scaleType="fitCenter"
        android:rotation="12"
        android:contentDescription="@string/brand_logo_description" />

    <!-- ── 텍스트 + 하단 브랜드 전체 레이아웃 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="56dp">

        <!-- "Making everyday life shine together" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brand_tagline_en"
            android:textColor="#0CC9B5"
            android:textSize="12sp"
            android:letterSpacing="0.02" />

        <!-- "나, 그리고" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/brand_tagline_line_1"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1" />

        <!-- "연인/가족의" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brand_tagline_line_2"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1" />

        <!-- "일상 네트워크" — 코드에서 teal→green 그라디언트 적용 -->
        <TextView
            android:id="@+id/textGradient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brand_tagline_line_3"
            android:textColor="#0CC9B5"
            android:textSize="40sp"
            android:textStyle="bold" />

        <!-- 여백 -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- "gleaum" 하단 브랜드 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/brand_wordmark"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

    </LinearLayout>

</FrameLayout>
