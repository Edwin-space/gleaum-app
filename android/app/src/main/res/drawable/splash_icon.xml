<?xml version="1.0" encoding="utf-8"?>
<!--
  글리움 스플래시 아이콘 (벡터)
  Android 12+ SplashScreen API용 — 240×240dp, 중앙 로고 영역은 72×72dp 이내
  배경은 windowSplashScreenIconBackgroundColor 로 설정

  글리움 로고: 그라디언트 다이아몬드 ◆ (회전한 정사각형)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 배경: 투명 (windowSplashScreenIconBackgroundColor로 제어) -->

    <!-- 다이아몬드 외형 (45도 회전 정사각형) -->
    <path
        android:pathData="M54,18 L90,54 L54,90 L18,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90">
                <item android:offset="0" android:color="#2EE895"/>
                <item android:offset="0.5" android:color="#0CC9B5"/>
                <item android:offset="1" android:color="#0084CC"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- 내부 흰색 소 다이아몬드 (글리움 BI 특징) -->
    <path
        android:pathData="M54,34 L70,54 L54,74 L38,54 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.92"/>

</vector>
