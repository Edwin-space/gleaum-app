<?xml version="1.0" encoding="utf-8"?>
<!--
  글리움 적응형 아이콘 전경 (Foreground)
  108×108dp 캔버스 기준 — 안전 영역은 중앙 72×72dp
  배경: ic_launcher_background.xml (#0F1A2E)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 외부 다이아몬드: 그린→틸→블루 그라디언트 -->
    <path
        android:pathData="M54,24 L84,54 L54,84 L24,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="24"
                android:startY="24"
                android:endX="84"
                android:endY="84">
                <item android:offset="0"   android:color="#2EE895"/>
                <item android:offset="0.5" android:color="#0CC9B5"/>
                <item android:offset="1"   android:color="#0084CC"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- 내부 흰색 다이아몬드 -->
    <path
        android:pathData="M54,38 L68,54 L54,70 L40,54 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.95"/>

</vector>
