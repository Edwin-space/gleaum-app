<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".GleaumApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:hardwareAccelerated="true">

        <!-- ── 스플래시 (런처) — 전체 화면 브랜딩 → RouterActivity 로 전환 ── -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/AppTheme.Splash"
            android:exported="true"
            android:noHistory="true">

            <!-- 앱 런처 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ── 라우터 — 세션 체크 후 Login 또는 Main 으로 분기 ──────────── -->
        <activity
            android:name=".RouterActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="true"
            android:noHistory="true">

            <!-- Deep Link: gleaum:// (OAuth 콜백) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="gleaum" />
            </intent-filter>

            <!-- App Links: https://www.gleaum.com -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.gleaum.com" />
            </intent-filter>

            <!-- App Links: https://gleaum.com -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="gleaum.com" />
            </intent-filter>

        </activity>

        <!-- ── 메인 액티비티 (Capacitor WebView) ──────────────────────── -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBar"
            android:launchMode="singleTask"
            android:exported="false"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <!-- ── 네이티브 로그인 화면 ────────────────────────────────────────── -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".NativeOnboardingActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── 네이티브 전체 메뉴 Shell ─────────────────────────────────── -->
        <activity
            android:name=".NativeMyMenuActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />

        <activity
            android:name=".NativeNotificationActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- ── Material 3 Compose Shell Preview (전환 검증용) ─────────────── -->
        <activity
            android:name=".Material3ShellPreviewActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- ── 네이티브 홈 ──────────────────────────────────────────────── -->
        <activity
            android:name=".NativeHomePortActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- ── 네이티브 일정 등록 ───────────────────────────────────────── -->
        <activity
            android:name=".NativeScheduleCreateActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── 네이티브 일정 목록/상세 ───────────────────────────────────── -->
        <activity
            android:name=".NativeScheduleListActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".NativeScheduleDetailActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".NativeBudgetActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".NativeBudgetEntryCreateActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".NativeSpaceActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />


        <!-- ── 회원가입 약관/개인정보 인앱 브라우저 ─────────────────────── -->
        <activity
            android:name=".LegalWebViewActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- ── Google AdMob ────────────────────────────────────────────────
             App ID: ca-app-pub-7426507548879721~6623452973
             Banner Unit: ca-app-pub-7426507548879721/6211229285
        -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-7426507548879721~6623452973" />

        <!-- ── FCM 기본 알림 설정 ──────────────────────────────────────── -->
        <!-- channel_id: MainActivity.createNotificationChannels() 와 반드시 일치 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="gleaum_notifications" />
        <!--
            알림 아이콘: Android 5.0+ 는 반드시 흰색 단색 실루엣 벡터 사용.
            @mipmap/ic_launcher(풀컬러) 는 회색 사각형으로 렌더되거나
            삼성/샤오미 등 일부 ROM 에서 알림 자체를 무시함.
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notify" />
        <!-- 알림 강조 색상 (글리움 브랜드 블루) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/gleaum_blue" />

        <service
            android:name=".GleaumFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FileProvider (파일 공유) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

    <!-- ── 권한 ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!--
        카메라·사진/동영상 라이브러리 권한은 선언하지 않는다.
        글리움의 이미지 사용은 사용자가 직접 선택하거나 촬영 앱에서 전달하는
        단발성 업로드이므로 Android Photo Picker / 시스템 파일 선택기 /
        WebView file chooser 의 URI grant 방식만 사용한다.
        Google Play 정책상 미디어 라이브러리 읽기 권한은 지속 접근이 핵심 기능인 앱에만 허용된다.
    -->

    <!-- Firebase Cloud Messaging -->
    <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" />
    <!-- Firebase Analytics / GA4 광고 ID 사용 선언 (Android 13+) -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!-- 태블릿에서도 설치 가능 (스마트폰 전용 기능 불필요) -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <!-- 생체인증은 선택 기능. 없는 기기는 기기 잠금/설정 미노출로 처리 -->
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />

</manifest>
